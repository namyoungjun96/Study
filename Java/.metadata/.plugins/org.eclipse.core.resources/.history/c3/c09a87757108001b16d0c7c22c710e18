public class Ride {
	Element el=new Element();

	int ride(int count) {
		count-=1;

		for(int i=0; i<el.ladder.length; i++) {
			try {
				if(el.ladder[i][count]==0) {
					System.out.println("(",i," ,",count,")");
					continue;
				}

				else if((el.ladder[i][count]+el.ladder[i][count+1])==2) {
					System.out.println(el.ladder[i][count]);
					count++;
				}
				else {
					System.out.println(el.ladder[i][count]);
					count--;
				}
			} catch(Exception e){
				if(el.ladder[i][count]-el.ladder[i][count-1]==0) {
					System.out.println(el.ladder[i][count]);
					count--;
				}
				else {
					continue;
				}
			}
		}
		return count+1;
	}
}
