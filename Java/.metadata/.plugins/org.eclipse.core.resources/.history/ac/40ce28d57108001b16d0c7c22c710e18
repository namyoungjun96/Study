import java.util.Scanner;

public class Start {
	public static void main(String[] args) {
		int input;

		Ride ri=new Ride();
		Element el=new Element();
		Scanner sc=new Scanner(System.in);
		
		System.out.println("사다리타기 게임");
		el.draw();

		while(true) {
			System.out.print("몇번을 원하시나요? : ");
			input=sc.nextInt();
			
			if(input==0)
				break;

			System.out.println(""+ri.ride(input));
		}

		sc.close();
	}
}
